{
  "name": "bloomrpc",
  "productName": "BloomRPC",
  "version": "1.6.0",
  "description": "GRPC GUI client",
  "main": "main.js",
  "scripts": {
    "build": "concurrently \"yarn build-main\" \"yarn build-renderer\"",
    "build-main": "cross-env NODE_ENV=production node --trace-warnings ./node_modules/webpack/bin/webpack --config webpack.config.main.prod.js",
    "build-renderer": "cross-env NODE_ENV=production node --trace-warnings ./node_modules/webpack/bin/webpack --config webpack.config.renderer.prod.js",
    "dev": "cross-env START_HOT=1 node ./internals/scripts/CheckPortInUse.js && cross-env START_HOT=1 yarn start-renderer-dev",
    "electron-rebuild": "electron-rebuild --parallel --force --types prod,dev,optional --module-dir app",
    "package": "yarn build && electron-builder build",
    "package-linux": "yarn build && electron-builder build --linux",
    "package-win": "yarn build && electron-builder build --win --x64",
    "postinstall": "node internals/scripts/CheckNativeDep.js && electron-builder install-app-deps",
    "prestart": "yarn build",
    "start": "cross-env NODE_ENV=production electron ./app/",
    "start-renderer-dev": "cross-env NODE_ENV=development webpack serve --config webpack.config.renderer.dev.js",
    "start-main-dev": "cross-env HOT=1 NODE_ENV=development electron ./app/main.dev.js",
    "package-mac-arm64": "yarn build && CSC_IDENTITY_AUTO_DISCOVERY=false CSC_LINK='' CSC_KEY_PASSWORD='' electron-builder build --mac zip --arm64",
    "package-mac": "yarn build && CSC_IDENTITY_AUTO_DISCOVERY=false CSC_LINK='' CSC_KEY_PASSWORD='' electron-builder build --mac --universal"
  },
  "build": {
    "productName": "BloomRPC",
    "appId": "io.github.utilitywarehouse.BloomRPC",
    "extraResources": [
      {
        "from": "static",
        "to": "static"
      }
    ],
    "extraFiles": [
      {
        "from": "resources/icon.ico",
        "to": "resources/icon.ico"
      }
    ],
    "files": [
      "dist/",
      "node_modules/",
      "app.html",
      "about/about.html",
      "main.prod.js",
      "main.prod.js.map",
      "package.json"
    ],
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "pkg",
          "arch": [
            "universal"
          ]
        }
      ],
      "notarize": false,
      "x64ArchFiles": "**/*",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "pkg": {
      "installLocation": "/Applications",
      "allowAnywhere": true,
      "allowCurrentUserHome": true,
      "allowRootDirectory": true
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Development"
    },
    "directories": {
      "buildResources": "resources",
      "output": "release"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uw-labs/bloomrpc.git"
  },
  "author": {
    "name": "Fabrizio Fenoglio (UtilityWarehouse)"
  },
  "license": "LGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/uw-labs/bloomrpc/issues"
  },
  "keywords": [
    "gRPC",
    "GUI",
    "bloomRPC",
    "BloomRPC",
    "gRPC GUI"
  ],
  "homepage": "https://github.com/uw-labs/bloomrpc",
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/jest": "^29.5.12",
    "@types/mousetrap": "^1.6.15",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/uuid": "^9.0.8",
    "chalk": "^4.1.2",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^11.0.0",
    "cross-env": "^7.0.3",
    "cross-spawn": "^7.0.3",
    "css-loader": "^6.10.0",
    "css-minimizer-webpack-plugin": "^6.0.0",
    "detect-port": "^1.5.1",
    "electron": "^27.3.0",
    "electron-builder": "^24.13.3",
    "electron-debug": "^3.2.0",
    "electron-devtools-installer": "^3.2.0",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.0",
    "mini-css-extract-plugin": "^2.8.1",
    "minimist": "^1.2.8",
    "rimraf": "^5.0.5",
    "sass": "^1.71.1",
    "sass-loader": "^14.1.1",
    "source-list-map": "^2.0.1",
    "style-loader": "^3.3.4",
    "terser-webpack-plugin": "^5.3.10",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "url-loader": "^4.1.1",
    "webpack": "^5.90.3",
    "webpack-bundle-analyzer": "^4.10.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "webpack-merge": "^5.10.0"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.6",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron/remote": "^2.1.2",
    "ace-builds": "^1.32.7",
    "antd": "^5.16.1",
    "electron-store": "^8.2.0",
    "grpc-web": "^1.5.0",
    "mousetrap": "^1.6.5",
    "protobufjs": "^7.2.6",
    "re-resizable": "^6.9.11",
    "react": "^18.2.0",
    "react-ace": "^10.1.0",
    "react-dom": "^18.2.0",
    "source-map-support": "^0.5.21",
    "uuid": "^9.0.1"
  },
  "engines": {
    "node": ">=18"
  }
}
